# Docker / database connection
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=myblog
DB_USER=postgres
DB_PASSWORD=your_password

# App runtime
NODE_ENV=production
NEXTAUTH_URL=https://blog.vixenahri.cn
NEXTAUTH_SECRET=your-secret-key-generate-with-openssl-rand-base64-32
NEXT_PUBLIC_SITE_URL=https://blog.vixenahri.cn

# Seeded admin account
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=your_secure_password

# Optional extra admin entry gate
ADMIN_ACCESS_KEY=your-secret-access-key

# Optional notifications and scheduler
RESEND_API_KEY=re_xxxxxxxxxxxx
CRON_SECRET=your-cron-secret

# Optional Cloudflare tunnel profile
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token
