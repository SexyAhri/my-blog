# Database
DATABASE_URL="postgresql://username:password@localhost:5432/myblog?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:5177"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Admin User (for initial setup)
ADMIN_EMAIL="admin@example.com"
ADMIN_NAME="Admin"
ADMIN_PASSWORD="your-secure-password"

# Admin Access Key (server-only; visit /admin/login/<key> once to set the gate cookie)
# Leave empty to disable the extra admin entry gate
ADMIN_ACCESS_KEY="your-secret-access-key"

# Email (Resend) - used for comment notifications
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Public site URL - used in emails and absolute links
NEXT_PUBLIC_SITE_URL="https://blog.vixenahri.cn"

# Cron Secret - required for the scheduled publish endpoint
CRON_SECRET="your-cron-secret"

# Docker auto-bootstrap options
RUN_DB_MIGRATIONS="true"
BOOTSTRAP_ADMIN_ON_EMPTY_DB="true"
DB_MIGRATION_MAX_RETRIES="30"
DB_MIGRATION_RETRY_INTERVAL="5"
